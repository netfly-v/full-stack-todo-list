# Prefer DATABASE_URL in production (Neon / Render)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local DB fallback (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=todo_user
PGPASSWORD=todo_password
PGDATABASE=todo_db

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3002

# Public API URL for Swagger server entry
PUBLIC_API_URL=http://localhost:3001

ACCESS_TOKEN_SECRET=change_me_access
REFRESH_TOKEN_SECRET=change_me_refresh
SUPERADMIN_BOOTSTRAP_SECRET=change_me_superadmin
